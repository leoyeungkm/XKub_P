# KUB Chain private key (deployer wallet)
# Testnet wallet: 0xe8900BFdB3AaaD4F472479f6d430eB39CbaBfa9F
KUB_PRIVATE_KEY=0x...

# ── For deploy-kub-factory.ts (mainnet) ──────────────────────────────────────
# Verify all addresses on bkcscan.com before using

# KUSDT on KUB Chain mainnet (likely 18 decimals — KAP-20 standard)
KUSDT_ADDRESS=
KUSDT_DECIMALS=18

# Diamon DEX
DIAMON_ROUTER=0xAb30a29168D792c5e6a54E4bcF1Aec926a3b20FA
DIAMON_FACTORY=

# KKUB (Wrapped KUB) — needed for testnet smoke test
