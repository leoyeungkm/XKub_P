# Treasury address (defaults to deployer if empty)
TREASURY_ADDRESS=

# ── For deploy-perp-testnet.ts / perp-price-keeper.ts ────────────────────────
# Price keeper bot wallet (defaults to deployer if empty)
KEEPER_ADDRESS=

# Oracle address for the keeper bot (from deployments/perp-*.json)
PERP_ORACLE_ADDRESS=

# Keeper poll interval in ms
KEEPER_INTERVAL_MS=15000

# Seed prices in whole USD (keeper corrects them right away)
SEED_BTC=100000
SEED_ETH=4000
SEED_KUB=1.5

# Optional
REPORT_GAS=false
